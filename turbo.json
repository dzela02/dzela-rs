{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [".env", ".env.local"],
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".output/**", ".vinxi/**", "build/**", ".next/**"],
      "env": ["VITE_*", "STRAPI_*", "ANTHROPIC_API_KEY"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["VITE_*", "STRAPI_*", "ANTHROPIC_API_KEY"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
